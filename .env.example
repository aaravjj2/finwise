# Supabase (required - get free at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI - set to "mock" to run without any API key (default)
# Or set OLLAMA_BASE_URL for free local AI (install ollama.ai)
# Or set ANTHROPIC_API_KEY for Claude
ANTHROPIC_API_KEY=mock
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Voice (optional - app works without this)
ELEVENLABS_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
