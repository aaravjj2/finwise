# FinWise Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# SUPABASE (Required)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# ANTHROPIC AI (Required)
# ===========================================
ANTHROPIC_API_KEY=sk-ant-your-api-key

# ===========================================
# ELEVENLABS VOICE (Required for voice features)
# ===========================================
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=your-voice-id

# ===========================================
# UPSTASH REDIS (Required for rate limiting)
# ===========================================
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ===========================================
# SENTRY (Optional - Error tracking)
# ===========================================
SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn

# ===========================================
# APP CONFIG
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FinWise

# ===========================================
# EXTERNAL APIS (Optional)
# ===========================================
# Exchange rate API for remittance comparison
EXCHANGE_RATE_API_KEY=your-exchange-rate-key

# Google Maps API for institution locator
GOOGLE_MAPS_API_KEY=your-google-maps-key
