{
  "name": "finwise",
  "version": "1.0.0",
  "description": "AI-powered financial literacy coach for emerging markets",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:ai": "docker-compose -f docker-compose.dev.yml up -d && npm run dev",
    "build": "next build",
    "start": "next start",
    "prepare:standalone": "mkdir -p .next/standalone/.next && rm -rf .next/standalone/.next/static .next/standalone/public && cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "start:standalone": "npm run prepare:standalone && node .next/standalone/server.js",
    "lint": "next lint",
    "check-types": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "format": "prettier --write .",
    "seed:demo": "npx ts-node scripts/seed-demo.ts",
    "import:institutions": "npx ts-node scripts/import-institutions.ts",
    "setup:local": "bash scripts/setup-local.sh",
    "audit:lighthouse": "lhci autorun --config=.lighthouserc.json",
    "audit:a11y": "npx ts-node scripts/a11y-audit.ts",
    "audit:all": "npm run audit:lighthouse && npm run audit:a11y"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "@tanstack/react-query": "^5.95.0",
    "@upstash/redis": "^1.34.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.15.0",
    "idb": "^8.0.1",
    "marked": "^17.0.5",
    "next": "14.2.35",
    "next-intl": "^3.25.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@sentry/nextjs": "^8.55.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.4.1",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.35",
    "jsdom": "^29.0.1",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
